    margin: 0 0 0.25rem;
    font-size: 1rem;
  }
  .docs-step p {
    margin: 0;
    font-size: 0.9rem;
  }
  .docs-step ul {
    margin: 0.5rem 0 0;
    padding-left: 1rem;
  }
  .docs-step li {
    font-size: 0.85rem;
  }

  .docs-table-wrap {
    overflow-x: auto;
    margin: 1rem 0;
    -webkit-overflow-scrolling: touch;
  }
  .docs-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    font-size: 0.9rem;
  }
